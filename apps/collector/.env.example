# SQLite path (default: ./data/draws.db)
COLLECTOR_DB_PATH=./data/draws.db

# mock | bingo18
COLLECTOR_ADAPTER=mock

# bingo18: tự đồng bộ full lịch sử khi khởi động (mặc định bật nếu adapter=bingo18)
COLLECTOR_SYNC_ON_START=1

# bingo18: lịch sử < 01/07/2026 từ bingo18.top
COLLECTOR_BINGO18_API_URL=https://bingo18.top/data/data.json
# bingo18: từ 01/07/2026 dùng kqxso.top (API ketquasoxo)
COLLECTOR_KQXSO_ENABLED=1
COLLECTOR_KQXSO_SINCE=2026-07-01
COLLECTOR_KQXSO_DRAWS_URL=https://kqxso.top/api/gbingo/draws
COLLECTOR_BINGO18_TIMEOUT_MS=10000

# mock adapter: synthetic draws for dev/soak
COLLECTOR_MOCK_INTERVAL_MS=30000

# Read-only HTTP API for Dashboard Lite (default :8788)
COLLECTOR_HTTP_PORT=8788
COLLECTOR_HTTP_CORS=http://localhost:5173
# Optional: show git commit on /dashboard (e.g. db8ab9a)
# COLLECTOR_GIT_COMMIT=db8ab9a
